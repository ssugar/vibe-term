{
  "name": "vibe-term",
  "version": "1.4.6",
  "description": "Terminal HUD for managing Claude Code sessions",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "vibe-term": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup src/cli.tsx --format esm --dts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:first": "standard-version --first-release"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssugar/vibe-term.git"
  },
  "keywords": [
    "vibe-term",
    "terminal",
    "tui",
    "hud",
    "tmux",
    "claude",
    "claude-code",
    "sessions"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ssugar/vibe-term/issues"
  },
  "homepage": "https://github.com/ssugar/vibe-term#readme",
  "dependencies": {
    "figures": "^6.1.0",
    "ink": "^6.6.0",
    "meow": "^14.0.0",
    "micromatch": "^4.0.8",
    "picocolors": "^1.1.1",
    "react": "^19.2.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "standard-version": "^9.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
